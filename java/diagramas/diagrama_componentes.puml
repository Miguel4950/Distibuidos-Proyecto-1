@startuml diagrama_componentes
' ============================================================================
' DIAGRAMA DE COMPONENTES — Interfaces y dependencias entre servicios
' ============================================================================

title Diagrama de Componentes — Sistema de Tráfico Urbano

left to right direction
skinparam nodesep 60
skinparam ranksep 80

package "PC1 — Ingesta" {
    [Sensores de Tráfico] as Sensores
    note right of Sensores
        PUB: camara, espira, gps
        Marshalling: json.dumps()
    end note

    [Broker ZMQ Multihilo] as Broker
    note right of Broker
        XSUB (bind :5555)
        XPUB (bind :5556)
    end note

    Sensores --> Broker : "PUB/SUB\n(connect → bind)"
}

package "PC2 — Cerebro" {
    [Servicio de Analítica] as Analitica
    note right of Analitica
        SUB tópicos (bind :5556)
        Reglas simples if/elif
        PUSH x3
    end note

    [Control de Semáforos] as CtrlSem
    note right of CtrlSem
        PULL :5563
        Estados: VERDE/ROJO
    end note

    [BD Réplica] as BDReplica
    note right of BDReplica
        PULL :5562
        REP :5564
    end note

    Analitica --> CtrlSem : "PUSH/PULL"
    Analitica --> BDReplica : "PUSH/PULL"
}

package "PC3 — Persistencia" {
    [BD Principal] as BDPrincipal
    note right of BDPrincipal
        PULL :5570
        REP :5571
    end note

    [Monitoreo y Consulta] as Monitoreo
    note left of Monitoreo
        REQ a Analítica
        REQ a BD Principal
        REQ a BD Réplica
    end note
}

' Flujos Maestros (Izquierda a Derecha)
Broker ==> Analitica : "PUB/SUB\n(XPUB → SUB)"
Analitica ==> BDPrincipal : "PUSH/PULL\nDatos procesados"

' Retro-Flujos de Consulta (Escritos al revés en código para cuidar la estética)
Analitica <== Monitoreo : "REQ/REP\nComandos directos"
BDPrincipal <== Monitoreo : "REQ/REP\nConsultas"
BDReplica <.. Monitoreo : "REQ/REP (failover)"

@enduml
