@startuml diagrama_secuencia
' ============================================================================
' DIAGRAMA DE SECUENCIA — Flujo completo incluyendo fallo de PC3
' Corregido para coincidir exactamente con los scripts procedimentales
' ============================================================================

title Diagrama de Secuencia (Visualizando Transacciones y Locks)

actor "Usuario\n(Operador)" as Usuario
participant "Sensores\n(PC1)" as Sensores
participant "Broker ZMQ\n(PC1)" as Broker
participant "Analítica\n(PC2)" as Analitica
participant "Ctrl Semáforos\n(PC2)" as Semaforos
participant "BD Réplica\n(PC2)" as BDReplica
participant "BD Principal\n(PC3)" as BDPrincipal
participant "Monitoreo\n(PC3)" as Monitoreo

== Flujo Normal de Datos ==

Sensores -> Broker : PUB evento JSON (camara)\n{sensor_id...}
Broker -> Broker : lock_contador.acquire()\ncontador_mensajes += 1\nlock_contador.release()
Broker -> Analitica : XPUB reenvía string
Analitica -> Analitica : if/elif (reglas Q,Vp,D)\nlock.acquire()\nActualiza: datos_intersecciones[inter]\nlock.release()
Analitica -> BDReplica : PUSH datos a réplica (Siempre 1ro)
BDReplica -> BDReplica : cursor.execute(INSERT)
Analitica -> BDPrincipal : PUSH datos a principal
BDPrincipal -> BDPrincipal : cursor.execute(INSERT)
Analitica -> Semaforos : PUSH comando\n{accion: CICLO_NORMAL}
Semaforos -> Semaforos : lock.acquire()\nsemaforos[inter]['verde_seg'] = 15\nlock.release()

== Detección de Congestión ==

Sensores -> Broker : PUB evento GPS
Broker -> Analitica : XPUB reenvía
Analitica -> Analitica : Evaluar: D≥40 → CONGESTION\nlock.acquire() / release()
Analitica -> Semaforos : PUSH comando\n{accion: EXTENDER_VERDE, 30s}
Semaforos -> Semaforos : lock.acquire()\nsemaforos[inter]['verde_seg'] = 30\nlock.release()
Analitica -> BDReplica : PUSH datos de Congestión
Analitica -> BDPrincipal : PUSH datos de Congestión

== Consulta del Usuario ==

Usuario -> Monitoreo : Opción 2: Histórica
Monitoreo -> BDPrincipal : REQ {tipo: CONSULTA_HISTORICA}
BDPrincipal -> BDPrincipal : cursor.execute(SELECT)
BDPrincipal -> Monitoreo : REP {resultados: [...]}
Monitoreo -> Usuario : Mostrar print()

== Priorización (Ambulancia) ==

Usuario -> Monitoreo : Opción 4: Priorizar INT-B3
Monitoreo -> Analitica : REQ {tipo: PRIORIZACION}
Analitica -> Semaforos : PUSH {accion: OLA_VERDE, 45s}
Semaforos -> Semaforos : lock.acquire()\nsemaforos[inter]['luz'] = VERDE\nlock.release()
Analitica -> Monitoreo : REP {status: OK}
Monitoreo -> Usuario : prints: Latencia X ms

== Fallo del PC3 — Enmascaramiento de Fallos ==

destroy BDPrincipal
note over BDPrincipal : PC3 se cae o red falla

Sensores -> Broker : PUB evento
Broker -> Analitica : XPUB reenvía
Analitica -> BDReplica : PUSH datos (éxito)
BDReplica -> BDReplica : cursor.execute(INSERT)
Analitica ->x BDPrincipal : PUSH datos → TIMEOUT\n(zmq.Again)
note right of Analitica
  **ENMASCARAMIENTO DE PRESIÓN**
  El flag zmq.NOBLOCK genera un
  try/except atrapando zmq.Again,
  marcando pc3_esta_vivo = False.
end note

Usuario -> Monitoreo : Opción 2: Histórica
Monitoreo ->x BDPrincipal : REQ → TIMEOUT\n(zmq.Again)
note right of Monitoreo
  **Reconexión transparente**
  except atrapa zmq.Again o ZMQError.
  Ejecuta socket.close() y crea
  nuevos sockets apuntando a PC2.
end note
Monitoreo -> BDReplica : REQ {tipo: CONSULTA_HISTORICA}
BDReplica -> BDReplica : cursor.execute(SELECT)
BDReplica -> Monitoreo : REP {fuente: BD_REPLICA...}
Monitoreo -> Usuario : Muestra resultados de réplica

@enduml
