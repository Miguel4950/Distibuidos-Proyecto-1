@startuml diagrama_clases
' ============================================================================
' DIAGRAMA ESTRUCTURAL DE MÓDULOS (Enfoque Junior Procedimental)
' ============================================================================

title Estructura Interna de Módulos (Procedimental) — Sistema de Tráfico Urbano

left to right direction
skinparam nodesep 50
skinparam ranksep 100
skinparam classBackgroundColor LightYellow

class "Sensores.java" <<module>> {
    + BROKER_IP: String
    + PUERTO_BROKER: int
    + INTERVALO: int
    + FILAS: String[]
    + COLUMNAS: int[]
    + INTERSECCIONES: String[][]
    --
    + timestampAhora(): String
    + generarEventoCamara(fila, col): JSONObject
    + generarEventoEspira(fila, col): JSONObject
    + generarEventoGps(fila, col): JSONObject
    + ejecutarSensor(tipo, fila, col, contexto): void
    + main(args): void
}

class "BrokerMultihilo.java" <<module>> {
    + BROKER_IP: String
    + PUERTO_XSUB: int
    + PUERTO_XPUB: int
    + contadorMensajes: int
    + lockContador: ReentrantLock
    --
    + hiloMetricas(): void
    + hiloProxy(contexto): void
    + main(args): void
}

class "Analitica.java" <<module>> {
    + BROKER_IP: String
    + ANALITICA_IP: String
    + BD_PRINCIPAL_IP: String
    + datosIntersecciones: HashMap
    + pc3EstaVivo: boolean
    + lock: ReentrantLock
    --
    + timestampAhora(): String
    + evaluarTrafico(Q, Vp, D): String
    + crearComandoSemaforo(...): JSONObject
    + hiloRecibirSensores(contexto): void
    + hiloAtenderMonitoreo(contexto): void
    + main(args): void
}

class "ControlSemaforos.java" <<module>> {
    + ANALITICA_IP: String
    + semaforos: HashMap
    + lock: ReentrantLock
    --
    + timestampAhora(): String
    + hiloCicloAutomatico(): void
    + hiloRecibirComandos(contexto): void
    + main(args): void
}

class "BdReplica.java" <<module>> {
    + REPLICA_IP: String
    + PUERTO_PULL: int
    + PUERTO_REP: int
    + BD_ARCHIVO: String
    --
    + timestampAhora(): String
    + crearTablas(): void
    + guardarEvento(registro): int
    + hiloRecibirDatos(contexto): void
    + hiloConsultas(contexto): void
    + main(args): void
}

class "BdPrincipal.java" <<module>> {
    + BD_IP: String
    + PUERTO_PULL: int
    + PUERTO_REP: int
    + BD_ARCHIVO: String
    --
    + timestampAhora(): String
    + crearTablas(): void
    + guardarEvento(registro): int
    + hiloRecibirDatos(contexto): void
    + hiloConsultas(contexto): void
    + main(args): void
}

class "Monitoreo.java" <<module>> {
    + ANALITICA_IP: String
    + BD_PRINCIPAL_IP: String
    + BD_REPLICA_IP: String
    + TIMEOUT: int
    + usandoReplica: boolean
    --
    + crearSocket(...)
    + consultarBd(...)
    + mostrarMenu(): void
    + main(args): void
}

' Flujos Maestros hacia adelante
"Sensores.java" --> "BrokerMultihilo.java" : PUB
"BrokerMultihilo.java" --> "Analitica.java" : XPUB
"Analitica.java" --> "ControlSemaforos.java" : PUSH
"Analitica.java" --> "BdPrincipal.java" : PUSH
"Analitica.java" --> "BdReplica.java" : PUSH

' Flujos Inversos (Monitoreo pide datos, las flechas se dibujan inversas
' para mantener analitica y Bds a la izq, y monitoreo a la der)
"Analitica.java" <-- "Monitoreo.java" : REQ
"BdPrincipal.java" <-- "Monitoreo.java" : REQ
"BdReplica.java" <.. "Monitoreo.java" : REQ (Failover)

@enduml
